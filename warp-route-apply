#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${CONFIG_DIR:-/etc/warp-route}"
STATE_DIR="${STATE_DIR:-/var/lib/warp-route}"
LOG_DIR="${LOG_DIR:-/var/log/warp-route}"
WG_INTERFACE="${WG_INTERFACE:-wgcf}"
IPSET_NAME="${IPSET_NAME:-WARP_IPS}"
GOOGLE_IPSET_NAME="${GOOGLE_IPSET_NAME:-WARP_GOOGLE}"
MARK_HEX="${MARK_HEX:-0xca6c}"
MARK_DEC="${MARK_DEC:-51820}"
ROUTE_TABLE="${ROUTE_TABLE:-51820}"
RULES_JSON="${CONFIG_DIR}/rules.json"
RESOLVED_FILE="${STATE_DIR}/resolved_ips.txt"
GOOGLE_FILE="${STATE_DIR}/google_ip_ranges.txt"
LOG_FILE="${LOG_DIR}/apply.log"
GOOGLE_RANGES_URL="${GOOGLE_RANGES_URL:-https://www.gstatic.com/ipranges/goog.json}"
GOOGLE_BUILTIN_SNAPSHOT="2026-05-18T19:03:53Z"

mkdir -p "$STATE_DIR" "$LOG_DIR"

log() {
  printf '%s %s\n' "$(date -Is)" "$*" | tee -a "$LOG_FILE" >/dev/null
}

ensure_ipset() {
  ipset create "$IPSET_NAME" hash:net family inet -exist
  ipset create "${IPSET_NAME}_TMP" hash:net family inet -exist
  ipset flush "${IPSET_NAME}_TMP"
  ipset create "$GOOGLE_IPSET_NAME" hash:net family inet -exist
  ipset create "${GOOGLE_IPSET_NAME}_TMP" hash:net family inet -exist
  ipset flush "${GOOGLE_IPSET_NAME}_TMP"
}

read_rules() {
  python3 - "$RULES_JSON" <<'PY'
import ipaddress
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text())
for value in data.get("ips", []):
    try:
        print("ip", ipaddress.ip_network(value, strict=False))
    except ValueError:
        print(f"invalid_ip {value}", file=sys.stderr)
for value in data.get("domains", []):
    value = str(value).strip().lower().rstrip(".")
    if value:
        print("domain", value)
PY
}

resolve_domain() {
  local domain="$1"
  if command -v dig >/dev/null 2>&1; then
    dig +short A "$domain" | awk '/^[0-9.]+$/ {print}'
  elif command -v getent >/dev/null 2>&1; then
    getent ahostsv4 "$domain" | awk '{print $1}' | sort -u
  else
    return 0
  fi
}


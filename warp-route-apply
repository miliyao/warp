populate_ipset() {
  : >"$RESOLVED_FILE"

  while read -r type value; do
    case "$type" in
      ip)
        ipset add "${IPSET_NAME}_TMP" "$value" -exist
        printf '%s direct\n' "$value" >>"$RESOLVED_FILE"
        ;;
      domain)
        while read -r ip; do
          [[ -z "$ip" ]] && continue
          ipset add "${IPSET_NAME}_TMP" "$ip" -exist
          printf '%s %s\n' "$ip" "$value" >>"$RESOLVED_FILE"
        done < <(resolve_domain "$value")
        ;;
    esac
  done < <(read_rules)

  ipset swap "${IPSET_NAME}_TMP" "$IPSET_NAME"
  ipset flush "${IPSET_NAME}_TMP"
  log "refreshed ${IPSET_NAME}"
}

populate_google_ipset() {
  local tmp_json tmp_ranges range_count fetched_json
  tmp_json="$(mktemp)"
  tmp_ranges="$(mktemp)"
  fetched_json=0

  if curl -4fsSL --retry 2 --connect-timeout 8 --max-time 25 "$GOOGLE_RANGES_URL" -o "$tmp_json"; then
    fetched_json=1
  elif ip link show "$WG_INTERFACE" >/dev/null 2>&1 &&
    curl -4fsSL --interface "$WG_INTERFACE" --retry 2 --connect-timeout 8 --max-time 25 "$GOOGLE_RANGES_URL" -o "$tmp_json"; then
    fetched_json=1
    log "fetched Google IP ranges via ${WG_INTERFACE}"
  else
    log "failed to fetch Google IP ranges; using built-in snapshot ${GOOGLE_BUILTIN_SNAPSHOT}"
  fi

  if [[ "$fetched_json" -eq 1 ]]; then
    if ! python3 - "$tmp_json" <<'PY' >"$tmp_ranges"
import ipaddress
import json
import sys
from pathlib import Path

data = json.loads(Path(sys.argv[1]).read_text())
for prefix in data.get("prefixes", []):
    value = prefix.get("ipv4Prefix")
    if not value:
        continue
    try:
        print(ipaddress.ip_network(value, strict=False))
    except ValueError:
        pass
PY
    then
      : >"$tmp_ranges"
      log "failed to parse Google IP ranges; using built-in snapshot ${GOOGLE_BUILTIN_SNAPSHOT}"
    fi
  else
    write_builtin_google_ranges "$tmp_ranges"
  fi

  range_count="$(grep -c . "$tmp_ranges" || true)"
  if [[ "$range_count" -eq 0 ]]; then
    write_builtin_google_ranges "$tmp_ranges"
    range_count="$(grep -c . "$tmp_ranges" || true)"
    log "Google IP ranges response contained no IPv4 prefixes; using built-in snapshot ${GOOGLE_BUILTIN_SNAPSHOT}"
  fi

  if [[ "$range_count" -eq 0 ]]; then
    rm -f "$tmp_json" "$tmp_ranges"
    log "built-in Google IP ranges are empty; keeping existing ${GOOGLE_IPSET_NAME}"
    return
  fi

  while read -r cidr; do
    [[ -z "$cidr" ]] && continue
    ipset add "${GOOGLE_IPSET_NAME}_TMP" "$cidr" -exist
  done <"$tmp_ranges"

  ipset swap "${GOOGLE_IPSET_NAME}_TMP" "$GOOGLE_IPSET_NAME"
  ipset flush "${GOOGLE_IPSET_NAME}_TMP"
  mv "$tmp_ranges" "$GOOGLE_FILE"
  rm -f "$tmp_json"
  log "refreshed ${GOOGLE_IPSET_NAME}"
}

ensure_iptables() {
  iptables -t mangle -C OUTPUT -m set --match-set "$IPSET_NAME" dst -j MARK --set-mark "$MARK_HEX" 2>/dev/null ||
    iptables -t mangle -A OUTPUT -m set --match-set "$IPSET_NAME" dst -j MARK --set-mark "$MARK_HEX"
  iptables -t mangle -C OUTPUT -m set --match-set "$GOOGLE_IPSET_NAME" dst -j MARK --set-mark "$MARK_HEX" 2>/dev/null ||
    iptables -t mangle -A OUTPUT -m set --match-set "$GOOGLE_IPSET_NAME" dst -j MARK --set-mark "$MARK_HEX"
}

ensure_policy_route() {
  if ! ip link show "$WG_INTERFACE" >/dev/null 2>&1; then
    echo "WireGuard interface ${WG_INTERFACE} is not up. Check wg-quick@${WG_INTERFACE}.service." >&2
    exit 1
  fi

  while ip -4 rule del fwmark "$MARK_DEC" table "$ROUTE_TABLE" 2>/dev/null; do
    :
  done
  while ip -4 rule del fwmark "$MARK_HEX" table "$ROUTE_TABLE" 2>/dev/null; do
    :
  done
  ip -4 rule add fwmark "$MARK_DEC" table "$ROUTE_TABLE"
  ip route replace default dev "$WG_INTERFACE" table "$ROUTE_TABLE"
}

main() {
  if [[ ! -f "$RULES_JSON" ]]; then
    echo "Missing ${RULES_JSON}" >&2
    exit 1
  fi

  ensure_ipset
  populate_ipset
  populate_google_ipset
  ensure_iptables
  ensure_policy_route
}

main "$@"
